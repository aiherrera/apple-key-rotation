# Optional: copy to .env for local tooling. This app has no required Vite env vars for the web build.

# Electron main process: URL opened by Help → Apple Key Rotation Help (Cmd+?). Set when packaging.
# HELP_URL=https://example.com/docs

# Optional: local npm run release:publish (R2 + GitHub). Matches docs/SECRETS.md and package.json build.publish.
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_R2_BUCKET=
# AWS_ACCESS_KEY_ID=          # R2 S3 API access key id
# AWS_SECRET_ACCESS_KEY=      # R2 S3 API secret
# R2_PUBLIC_BASE_URL=         # optional: https://your-public-host/apple-key-rotation (no trailing slash)
