# Optional: copy to .env for local tooling. This app has no required Vite env vars for the web build.

# Electron main process: URL opened by Help → Apple Key Rotation Help (Cmd+?). Set when packaging.
# HELP_URL=https://example.com/docs

# Release / CI: electron-builder needs R2_PUBLIC_BASE_URL for the generic (auto-update) entry in package.json build.publish.
# After a GitHub publish, scripts/sync-release-to-r2.mjs mirrors release/ to R2 (same vars + AWS_* for S3 API). See docs/SECRETS.md.
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_R2_BUCKET=
# AWS_ACCESS_KEY_ID=          # R2 S3 API access key id
# AWS_SECRET_ACCESS_KEY=      # R2 S3 API secret
# R2_PUBLIC_BASE_URL=         # https://your-public-host/apple-key-rotation (no trailing slash)
